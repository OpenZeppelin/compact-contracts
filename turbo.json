{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": ["GITHUB_ACTIONS", "GITHUB_STEP_SUMMARY"],
  "tasks": {
    "compile:crypto": {
      "dependsOn": ["^build"],
      "env": ["COMPACT_HOME", "SKIP_ZK"],
      "inputs": ["src/crypto/**/*.compact"],
      "outputLogs": "new-only",
      "outputs": ["artifacts/**/"]
    },
    "compile:security": {
      "dependsOn": ["^build"],
      "env": ["COMPACT_HOME", "SKIP_ZK"],
      "inputs": ["src/security/**/*.compact"],
      "outputLogs": "new-only",
      "outputs": ["artifacts/**/"]
    },
    "compile:utils": {
      "dependsOn": ["^build"],
      "env": ["COMPACT_HOME", "SKIP_ZK"],
      "inputs": ["src/utils/**/*.compact"],
      "outputLogs": "new-only",
      "outputs": ["artifacts/**/"]
    },
    "compile:access": {
      "dependsOn": ["^build", "compile:utils"],
      "env": ["COMPACT_HOME", "SKIP_ZK"],
      "inputs": ["src/access/**/*.compact"],
      "outputLogs": "new-only",
      "outputs": ["artifacts/**/"]
    },
    "compile:archive": {
      "dependsOn": ["^build", "compile:utils"],
      "env": ["COMPACT_HOME", "SKIP_ZK"],
      "inputs": ["src/archive/**/*.compact"],
      "outputLogs": "new-only",
      "outputs": ["artifacts/**/"]
    },
    "compile:multisig": {
      "dependsOn": ["^build", "compile:utils"],
      "env": ["COMPACT_HOME", "SKIP_ZK"],
      "inputs": ["src/multisig/**/*.compact"],
      "outputLogs": "new-only",
      "outputs": ["artifacts/**/"]
    },
    "compile:token": {
      "dependsOn": ["^build", "compile:utils"],
      "env": ["COMPACT_HOME", "SKIP_ZK"],
      "inputs": ["src/token/**/*.compact"],
      "outputLogs": "new-only",
      "outputs": ["artifacts/**/"]
    },
    "compile:integration": {
      "dependsOn": ["^build"],
      "env": ["COMPACT_HOME", "SKIP_ZK"],
      "inputs": ["test/integration/**/*.compact"],
      "outputLogs": "new-only",
      "outputs": ["artifacts/**/"]
    },
    "compile": {
      "dependsOn": [
        "compile:crypto",
        "compile:security",
        "compile:utils",
        "compile:access",
        "compile:multisig",
        "compile:token"
      ]
    },
    "test": {
      "dependsOn": ["compile"],
      "env": ["COMPACT_HOME"],
      "outputs": [],
      "cache": false
    },
    "test:coverage": {
      "dependsOn": ["compile"],
      "env": ["COMPACT_HOME"],
      "outputs": [],
      "cache": false
    },
    "test:integration": {
      "dependsOn": ["compile:integration"],
      "env": ["COMPACT_HOME"],
      "outputs": [],
      "cache": false
    },
    "test:harness": {
      "outputs": [],
      "cache": false
    },
    "test:harness:live": {
      "dependsOn": ["test:harness"],
      "env": ["COMPACT_HOME"],
      "outputs": [],
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "env": ["COMPACT_HOME"],
      "inputs": [
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "src/**/*.compact",
        "tsconfig.json",
        "tsconfig.build.json",
        ".env"
      ],
      "outputs": ["dist/**"]
    },
    "types": {
      "dependsOn": ["@openzeppelin/compact-contracts#compile"],
      "outputs": [],
      "cache": false
    },
    "//#lint": {},
    "//#lint:ci": {},
    "//#lint:fix": {
      "cache": false
    },
    "clean": {
      "outputs": [],
      "cache": false
    }
  }
}
