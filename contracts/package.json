{
  "name": "@openzeppelin/compact-contracts",
  "version": "0.0.1-alpha.1",
  "description": "OpenZeppelin Compact contract library",
  "keywords": [
    "openzeppelin",
    "compact",
    "midnight",
    "contracts",
    "security"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenZeppelin/compact-contracts.git"
  },
  "license": "MIT",
  "author": "OpenZeppelin Community <maintainers@openzeppelin.org>",
  "bugs": {
    "url": "https://github.com/OpenZeppelin/compact-contracts/issues"
  },
  "homepage": "https://docs.openzeppelin.com/contracts-compact/",
  "type": "module",
  "imports": {
    "#test-utils/address.js": "./test-utils/address.js",
    "#test-utils/e2e-global-setup.js": "./test-utils/e2e-global-setup.ts",
    "#test-utils/e2e-shared-state.js": "./test-utils/e2e-shared-state.ts",
    "#test-utils/e2e-environment.js": "./test-utils/e2e-environment.ts"
  },
  "scripts": {
    "compact": "compact-compiler",
    "compact:access": "compact-compiler --dir access --skip-zk",
    "compact:archive": "compact-compiler --dir archive",
    "compact:security": "compact-compiler --dir security",
    "compact:token": "compact-compiler --dir token",
    "compact:utils": "compact-compiler --dir utils",
    "build": "compact-builder",
    "test": "compact-compiler --skip-zk && vitest --project unit",
    "test:e2e": "vitest --project e2e",
    "types": "tsc -p tsconfig.json --noEmit",
    "clean": "git clean -fXd"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@openzeppelin-compact/compact": "workspace:^"
  },
  "devDependencies": {
    "@midnight-ntwrk/compact-js": "^2.4.3",
    "@midnight-ntwrk/midnight-js-contracts": "^3.1.0",
    "@midnight-ntwrk/testkit-js": "^3.1.0",
    "@midnight-ntwrk/wallet-sdk-dust-wallet": "^1.0.0",
    "@midnight-ntwrk/wallet-sdk-facade": "^1.0.0",
    "@midnight-ntwrk/wallet-sdk-unshielded-wallet": "^1.0.0",
    "@openzeppelin-compact/contracts-simulator": "workspace:^",
    "@tsconfig/node24": "^24.0.3",
    "@types/node": "24.10.0",
    "axios": "^1.13.6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "testcontainers": "^11.12.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}