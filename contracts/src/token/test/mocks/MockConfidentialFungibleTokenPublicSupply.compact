// WARNING: FOR TESTING PURPOSES ONLY.
// This contract exposes internal circuits and bypasses safety checks that the
// corresponding production contract relies on. DO NOT deploy or use this
// contract in any production application.

pragma language_version >= 0.23.0;

import CompactStandardLibrary;

import "../../extensions/ConfidentialFungibleTokenPublicSupply" prefix ConfidentialFungibleTokenPublicSupply_;

// Surface the supply ledger cell unprefixed so tests can read it via
// `getPublicState()` and assert the getter returns it verbatim.
import { _totalSupply } from "../../extensions/ConfidentialFungibleTokenPublicSupply";
export { _totalSupply };

// Unit mock for the ConfidentialFungibleTokenPublicSupply extension in isolation. The
// extension imports no token module, so the accounting blocks and getter are
// driven directly here. The extension needs no initialization.

export circuit _addSupply(value: Uint<128>): [] {
  ConfidentialFungibleTokenPublicSupply__addSupply(value);
}

export circuit _subSupply(value: Uint<128>): [] {
  ConfidentialFungibleTokenPublicSupply__subSupply(value);
}

export circuit totalSupply(): Uint<128> {
  return ConfidentialFungibleTokenPublicSupply_totalSupply();
}
