{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": [
    "src/**/*.ts"
  ],
  "exclude": ["src/archive/"],
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "paths": {
      "@artifacts/*": ["./artifacts/*"],
      "@src/*": ["./src/*"]
    }
  }
}