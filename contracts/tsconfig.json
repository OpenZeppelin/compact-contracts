{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": [
    "src/**/test/*.e2e.test.ts"
  ],
  "exclude": [
    "src/archive/"
  ],
  "compilerOptions": {
    "paths": {
      "#test-utils/*": [
        "./test-utils/*"
      ]
    },
    "rootDir": ".",
    "types": [
      "vitest/globals",
      "node"
    ],
    "outDir": "dist",
    "declaration": true,
    "allowJs": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
  }
}